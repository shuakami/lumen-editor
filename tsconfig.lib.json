  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "allowImportingTsExtensions": false,
    "outDir": "dist-lib/types"
  },
  "include": [
    "src/lib.ts",
    "src/entries",
